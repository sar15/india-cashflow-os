# India Cashflow OS - Environment Variables
# Copy this file to .env and fill in the values

# --- Supabase PostgreSQL ---
# Get this from Supabase Dashboard > Settings > Database > Connection String > URI
# Replace [YOUR-PASSWORD] with your database password
DATABASE_URL=postgresql://postgres.pkgzcyaxrzwxnnawrvhd:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Supabase Project URL and Service Key
# Dashboard > Settings > API
SUPABASE_URL=https://pkgzcyaxrzwxnnawrvhd.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- API Configuration ---
CASHFLOW_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CASHFLOW_LOG_LEVEL=INFO
CASHFLOW_DISABLE_DEMO_AUTH=1

# --- Auth tokens (JSON array for multi-user) ---
# Format: [{"token":"abc123","org_id":"org-1","role":"owner","name":"Admin"}]
CASHFLOW_AUTH_TOKENS_JSON=[]

# --- Frontend (.env.local in apps/web) ---
# API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# CASHFLOW_SESSION_SECRET=generate-a-random-32-char-string
